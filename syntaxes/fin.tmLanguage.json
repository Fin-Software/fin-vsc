{
    "scopeName": "source.fin",
    "fileTypes": ["fn"],
    "repository": {
        "block_comment": {
            "name": "comment.block.fin", "begin": "<><", "end": "><>", "patterns": [{ "include": "#block_comment" }]
        },
        "comments": {
            "patterns": [{
                "include": "#block_comment"
            },
            {
                "name": "comment.block.javadoc", "begin": "\\(%", "end": "%\\)"
            },
            {
                "name": "comment.line.fin", "match": "##.*$"
            }]
        },
        "nominal-operators": {
            "patterns": [{
                "name": "keyword.control.fin",
                "match": "\\b(?:and|continue|defer|else|elseif|enum|extend|fallt|for|fin|if|impl|interface|or|orelse|rescue|return|struct|switch|module|unreachable|while|needs|inline|unroll)\\b"
            },
            {
                "name": "storage.modifier.storage-class.fin", "match": "\\b(?:align|alias|dyn)\\b"
            },
            {
                "name": "keyword.other.fin", "match": "@[A-Za-z_]\\w*"
            }]
        },
        "constants-faults": {
            "patterns": [{
                "name": "constant.language.fin", "match": "\\b(?:true|false|null|undefined)\\b"
            },
            {
                "name": "constant.language.fin", "match": "\\b[A-Z][A-Za-z0-9]*#"
            },
            {
                "name": "constant.language.fin", "match": "\\b[A-Z][A-Z0-9_]*\\b"
            }]
        },
        "types": {
            "patterns": [{
                "name": "entity.name.type.fin",
                "match": "\\b(?:void|bool|char|u8|i8|u16|i16|int|u32|rune|u64|i64|u128|i128|ureg|reg|f16|bf16|f32|f64|any)\\b"
            },
            {
                "name": "entity.name.type.fin",
                "match": "\\b[A-Z]\\w*"
            }]
        },
        "calls": {
            "name": "entity.name.function.call.fin", "match": "\\w+(?=\\()"
        },
        "symbolic-operators": {
            "patterns": [{
                "name": "keyword.operator.fin",
                "match": "(?:\\.sizeof\\b|\\.type\\b|\\.len\\b|\\.\\.\\.|\\.\\.|>>=|>>|>=|>|<<=|<<|<=|<|\\*%\\=|\\*%|\\*\\=|\\*\\*|\\*|\\+%\\=|\\+%|\\+\\=|\\+\\+|\\+|-%\\=|-%|\\-\\=|\\-|&=|&|%=|%|\\^=|\\^|\\/=|/|\\|=|!=|!|==|=|\\?|#)"
            },
            {
                "name": "keyword.operator.fin", "match": "(?:(?<=\\s)\\|(?=\\s)|(?<=\\S)\\|(?=\\S))"
            }]
        },
        "numbers": {
            "patterns": [{
                "name": "constant.numeric.fin", "match": "\\b0b[01]('?[01])*\\b"
            },
            {
                "name": "constant.numeric.fin", "match": "\\b0o[0-7]('?[0-7])*\\b"
            },
            {
                "name": "constant.numeric.fin", "match": "\\b0x[0-9A-Fa-f]('?[0-9A-Fa-f])*\\b"
            },
            {
                "name": "constant.numeric.fin", "match": "\\b\\d('?\\d)*(?:\\.\\d('?\\d)*)?(?:[eE][+-]?\\d('?\\d)*)?\\b"
            }]
        }
    },
    "patterns": [
        { "include": "#comments" },
        { "include": "#nominal-operators" },
        { "include": "#constants-faults" },
        { "include": "#types" },
        { "include": "#calls" },
        { "include": "#symbolic-operators" },
        { "include": "#numbers" }
    ]
}
